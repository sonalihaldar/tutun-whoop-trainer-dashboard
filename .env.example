# --- WHOOP OAuth app credentials ---
# Get these from https://developer-dashboard.whoop.com after creating an app.
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret

# Must exactly match the Redirect URI you register in the WHOOP developer dashboard.
# Locally:  http://localhost:3000/auth/whoop/callback
# Deployed: https://YOUR-APP-NAME.onrender.com/auth/whoop/callback
WHOOP_REDIRECT_URI=http://localhost:3000/auth/whoop/callback

# --- App security ---
# Password YOU use to log into your own dashboard (the trainer never sees this).
ADMIN_PASSWORD=change-me-please

# Random long string used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-char-hex-string

# --- Misc ---
# Port the server listens on. Render sets this automatically; only needed for local dev.
PORT=3000

# How often (minutes) the server auto-syncs with WHOOP while it's running.
SYNC_INTERVAL_MINUTES=30
